{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/exam/:id", "destination": "/exam.html?id=:id" },
    { "source": "/prova/:id", "destination": "/exam.html?id=:id" }
  ]
}
